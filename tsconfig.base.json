{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@graphtrace/shared": ["packages/shared/src/index.ts"],
      "@graphtrace/config": ["packages/config/src/index.ts"],
      "@graphtrace/storage": ["packages/storage/src/index.ts"],
      "@graphtrace/indexer": ["packages/indexer/src/index.ts"],
      "@graphtrace/query-engine": ["packages/query-engine/src/index.ts"],
      "@graphtrace/server": ["packages/server/src/index.ts"],
      "@graphtrace/mcp": ["packages/mcp/src/index.ts"],
      "@graphtrace/cli": ["packages/cli/src/index.ts"]
    }
  }
}
