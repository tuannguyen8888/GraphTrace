{
  "name": "graphtrace",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "bin": {
    "graphtrace": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean --tsconfig ../../tsconfig.json"
  },
  "dependencies": {
    "@graphtrace/config": "workspace:*",
    "@graphtrace/indexer": "workspace:*",
    "@graphtrace/mcp": "workspace:*",
    "@graphtrace/query-engine": "workspace:*",
    "@graphtrace/server": "workspace:*",
    "@graphtrace/shared": "workspace:*",
    "@graphtrace/storage": "workspace:*",
    "commander": "^14.0.1"
  }
}
